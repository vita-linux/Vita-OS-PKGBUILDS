# Maintainer: Angel vita-arch@proton.me
pkgname=vita-xfce-wallpapers
_pkgname=vita-xfce-wallpapers
_destname="/usr"
# _licensedir="/usr/share/vita-os/licenses/"
pkgver=2
pkgrel=7
groups=(vita-core)
pkgdesc="Wallpapers files for Vita-OS"
arch=('x86_64')
url="https://gitlab.com/vita-linux/vita-xfce/themes/$_pkgname"
license=('GPL3')
makedepends=('git')
depends=()
#conflicts=('')
provides=("${pkgname}")
options=( !strip !emptydirs )
source=(${pkgname}::"git+$url")
sha256sums=('SKIP')
#install='readme.install'
package() {
  install -dm755 "$pkgdir$_destname"
  cp -r "$srcdir/$pkgname/$_destname/"* "$pkgdir/$_destname"
}
