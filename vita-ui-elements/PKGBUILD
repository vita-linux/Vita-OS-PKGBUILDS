# Maintainer: Angel <vita-arch@proton.me>
pkgname=vita-ui-elements
_pkgname=vita-ui-elements
_destname="/usr"
pkgver=3
pkgrel=5
groups=(vita-core)
pkgdesc="Vita-OS UI Elements"
arch=('x86_64')
url="https://gitlab.com/vita-linux/$_pkgname"
license=('GPL3')
makedepends=('git')
depends=()
provides=("${pkgname}")
options=( !strip !emptydirs )
source=(${pkgname}::"git+$url")
sha256sums=('SKIP')
package() {
    install -dm755 "$pkgdir$_destname"
    cp -r "$srcdir/$pkgname/$_destname/"* "$pkgdir/$_destname"
}
