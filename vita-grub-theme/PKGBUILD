pkgname=vita-grub-theme
_pkgname=vita-grub-theme
_destname1="/usr"
_destname2="/boot"
pkgver=2
pkgrel=5
groups=(vita-core)
pkgdesc="Grub Theme for Vita-OS"
arch=('x86_64')
url="https://gitlab.com/vita-linux/vita-themes/$_pkgname"
license=('GPL3')
makedepends=('git')
depends=()
#conflicts=('')
provides=("${pkgname}")
options=( !strip !emptydirs )
source=(${pkgname}::"git+https://gitlab.com/vita-linux/vita-themes/${_pkgname}")
sha256sums=('SKIP')
package() {
  install -dm755 "$pkgdir$_destname1"
  cp -r "$srcdir/$pkgname/$_destname1/"* "$pkgdir/$_destname1"

  install -dm755 "$pkgdir$_destname"
  cp -r "$srcdir/$pkgname/$_destname2/"* "$pkgdir/$_destname2"
}
