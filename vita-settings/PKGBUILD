pkgname=vita-settings
_pkgname=vita-settings
_destname1="/etc"
_destname1="/usr"
pkgver=2
pkgrel=4
groups=("vita-core")
pkgdesc="Configuration files for Vita-OS"
arch=('x86_64')
url="https://gitlab.com/vita-linux/$_pkgname"
license=('GPL3')
makedepends=('git')
depends=()
# conflicts=()
provides=("${pkgname}")
options=( !strip !emptydirs )
source=(${pkgname}::"git+https://gitlab.com/vita-linux/${_pkgname}")
sha256sums=('SKIP')
#install='readme.install'
package() {
	install -dm755 "$pkgdir$_destname1"
	cp -r "$srcdir/$pkgname/$_destname1/"* "$pkgdir/$_destname1"

	install -dm755 "$pkgdir$_destname2"
	cp -r "$srcdir/$pkgname/$_destname2/"* "$pkgdir/$_destname2"
}
